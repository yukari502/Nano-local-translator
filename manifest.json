{
  "manifest_version": 3,
  "name": "Nano local translator",
  "version": "1.1.2",
  "description": "Open-source, local AI web translator with bilingual support, powered by Chrome's built-in AI — no external services required",
  "permissions": [
    "storage",
    "activeTab",
    "tts"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "img/Icon.png"
  },
  "icons": {
    "16": "img/Icon.png",
    "48": "img/Icon.png",
    "128": "img/Icon.png"
  },
  "commands": {
    "translate-page": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Translate current page"
    }
  }
}